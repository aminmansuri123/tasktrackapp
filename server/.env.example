PORT=4000
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/tasktrack?retryWrites=true&w=majority
JWT_SECRET=generate-a-long-random-string-here
# Comma-separated origins, e.g. https://aminmansuri123.github.io,http://localhost:8080
FRONTEND_ORIGIN=https://aminmansuri123.github.io
MASTER_EMAIL=mansuri.amin1@gmail.com
MASTER_PASSWORD=your-master-password-only-on-render
NODE_ENV=development

# --- Email (optional — leave blank to disable) ---
#
# Render / many clouds block outbound SMTP → use Resend (HTTPS, works everywhere):
# 1) Create account at https://resend.com and an API key
# 2) Set RESEND_API_KEY=re_xxxx
# 3) EMAIL_FROM: verified domain sender, e.g. "Task Tracker <noreply@yourdomain.com>"
#    For quick tests only: omit EMAIL_FROM to use onboarding@resend.dev (can only send to your own inbox)
RESEND_API_KEY=
EMAIL_FROM=
#
# Alternative: SMTP (works on VPS / home; often fails on Render):
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Cron schedule for daily reminders (default: 8:00 AM IST)
REMINDER_CRON=0 8 * * *
