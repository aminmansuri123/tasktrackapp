PORT=4000
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/tasktrack?retryWrites=true&w=majority
JWT_SECRET=generate-a-long-random-string-here
# Comma-separated origins, e.g. https://aminmansuri123.github.io,http://localhost:8080
FRONTEND_ORIGIN=https://aminmansuri123.github.io
MASTER_EMAIL=mansuri.amin1@gmail.com
MASTER_PASSWORD=your-master-password-only-on-render
NODE_ENV=development

# --- Email (optional — leave blank to disable) ---
#
# Recommended on Render: Resend + your own domain (HTTPS; outbound SMTP to Gmail is blocked on Render).
#
# 1) Resend: add domain aminmansuri.xyz, add DNS (DKIM, SPF/MX, optional DMARC) until the domain shows Verified.
# 2) Resend: create an API key → set RESEND_API_KEY below.
# 3) EMAIL_FROM must use an address on the verified domain, e.g.:
#    Task Tracker <no_reply@aminmansuri.xyz>
# 4) Render: set RESEND_API_KEY and EMAIL_FROM. Leave SMTP_EMAIL and SMTP_PASSWORD empty to skip Gmail SMTP.
#
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Task Tracker <no_reply@aminmansuri.xyz>
#
# Alternative: SMTP only (local/VPS; often times out on Render):
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Cron schedule for daily reminders (default: 8:00 AM IST)
REMINDER_CRON=0 8 * * *
